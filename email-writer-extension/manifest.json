{
  "name": "Email Writer Assistant",
  "description": "AI powered email writing assistant",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8080/*"
  ],
  "content_scripts": [
    {
      "js": ["content.js"],
      "css": ["content.css"],
      "matches": ["https://mail.google.com/*"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [ "icons/*" ],
      "matches": [ "https://mail.google.com/*" ]
    }
  ],
  "run_at": "document_end",
  "action": {
    "default_title": "Email Writer Assistant"
  }
}